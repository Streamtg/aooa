#!/usr/bin/env bash
set -euo pipefail
ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "$ROOT_DIR"
mkdir -p bin
GOOS=linux GOARCH=amd64 go build -o bin/qooq-cinema-bot-linux-amd64 .
GOOS=linux GOARCH=arm64 go build -o bin/qooq-cinema-bot-linux-arm64 .
echo "✅ Binarios generados en bin/"
